msgstr "<span color='green' font-size='small'>正確</span>"

msgid "<span color='green' font-size='x-large'>Calibration Succeeded!</span>"
msgstr "<span color='green' font-size='x-large'>校準成功！</span>"

msgid "<span color='red' font-size='small'>Nozzle not clean</span>"
msgstr "<span color='red' font-size='small'>噴嘴未清理</span>"


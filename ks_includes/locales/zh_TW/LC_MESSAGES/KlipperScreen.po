"span>"
msgstr "<span color='#0066CC' font-size='x-large'>校準結果：優秀</span>"

msgid ""
"<span color='#0066CC' font-size='x-large'>Probe result: Excellent</span>"
msgstr "<span color='#0066CC' font-size='x-large'>探測結果：優秀</span>"

msgid ""
"<span color='#FF0000' font-size='x-large'>Calibration result: Poor</span>"
msgstr "<span color='#FF0000' font-size='x-large'>校準結果：較差</span>"

msgid "<span color='#FF0000' font-size='x-large'>Probe result: Poor</span>"
msgstr "<span color='#FF0000' font-size='x-large'>探測結果：較差</span>"


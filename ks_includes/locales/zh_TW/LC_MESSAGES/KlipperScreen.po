msgstr "<span color='red' font-size='small'>位置偏移</span>"

msgid "<span color='red' font-size='x-large'>Calibration Failed!</span>"
msgstr "<span color='red' font-size='x-large'>校準失敗！</span>"

msgid "<span color='red'>Load timeout!</span>"
msgstr "<span color='red'>加載超時！</span>"

